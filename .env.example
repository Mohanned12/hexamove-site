# Server
PORT=3000
NODE_ENV=development

# Public information displayed on the website
BUSINESS_NAME=Hexamove
PUBLIC_PHONE=+33 7 46 73 86 56
PUBLIC_EMAIL=Contact@hexamove.fr
WHATSAPP_NUMBER=33746738656
SERVICE_AREA=France · Belgique · Suisse · Luxembourg · Toute l’Europe
BUSINESS_HOURS=7j/7 · 8h–17h
BUSINESS_TIMEZONE=Europe/Paris

# Separate multiple origins with commas only when the frontend is hosted elsewhere.
# Leave empty when the same Node server hosts the website.
ALLOWED_ORIGINS=

# Email notifications
# All new customer requests are sent to this address.
# You can change this address later directly in .env.
RESERVATION_EMAIL=devis@hexamove.fr

# Gmail account used only to SEND notification emails.
# Enable 2-step verification and create a Google App Password.
GMAIL_USER=your_sender@gmail.com
GMAIL_APP_PASSWORD=your_16_character_google_app_password

# Optional legacy setting. RESERVATION_EMAIL takes priority.
OWNER_EMAIL=

# Secure tokens used for validated European addresses and route calculations.
# Generate a long random value before production deployment.
QUOTE_SECRET=replace_with_a_long_random_secret

# European address autocomplete and road-distance services.
# The defaults use Photon (OpenStreetMap geocoding) and OSRM routing.
GEOCODING_API_URL=https://photon.komoot.io/api/
ROUTING_API_URL=https://router.project-osrm.org/route/v1/driving
EXTERNAL_API_TIMEOUT_MS=10000
EXTERNAL_API_USER_AGENT=Hexamove-Europe-Quote/2.0
